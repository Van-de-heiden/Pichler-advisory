<!-- Contact Modal — wire up #contact-form action to your email backend (e.g. Resend, Web3Forms) -->
<dialog
  id="contact-modal"
  class="bg-white rounded-xl p-10 shadow-lg w-full max-w-[520px] mx-auto border-0
         backdrop:bg-ink/55 backdrop:backdrop-blur-sm"
>
  <!-- Close -->
  <button
    id="modal-close-btn"
    class="absolute top-5 right-5 text-taupe hover:text-ink transition-colors duration-[180ms] ease-standard bg-transparent border-0 cursor-pointer p-1"
    aria-label="Schließen"
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    </svg>
  </button>

  <!-- Form state -->
  <div id="form-state">
    <span class="eyebrow">Erstgespräch anfragen</span>
    <h2 class="font-display font-medium text-[32px] tracking-[-0.02em] text-ink mt-3 mb-2">
      Gespräch vereinbaren
    </h2>
    <p class="text-[15px] leading-relaxed text-slate mb-6">
      Ich antworte persönlich auf jede ernsthafte Anfrage. Vertraulich, ohne Verpflichtung.
    </p>

    <form id="contact-form" class="flex flex-col gap-4">
      <div class="grid grid-cols-2 gap-4">
        <label class="flex flex-col gap-1.5">
          <span class="text-[11px] tracking-[0.1em] uppercase text-taupe font-semibold">Name</span>
          <input
            type="text"
            name="name"
            placeholder="Ihr Name"
            required
            class="font-body text-[15px] text-ink px-[14px] py-3 border border-stone rounded-md bg-white
                   outline-none transition-all duration-[180ms] ease-standard
                   focus:border-bordeaux-700 focus:ring-2 focus:ring-bordeaux-50 placeholder:text-taupe"
          />
        </label>
        <label class="flex flex-col gap-1.5">
          <span class="text-[11px] tracking-[0.1em] uppercase text-taupe font-semibold">Firma</span>
          <input
            type="text"
            name="company"
            placeholder="Ihr Betrieb"
            class="font-body text-[15px] text-ink px-[14px] py-3 border border-stone rounded-md bg-white
                   outline-none transition-all duration-[180ms] ease-standard
                   focus:border-bordeaux-700 focus:ring-2 focus:ring-bordeaux-50 placeholder:text-taupe"
          />
        </label>
      </div>
      <label class="flex flex-col gap-1.5">
        <span class="text-[11px] tracking-[0.1em] uppercase text-taupe font-semibold">E-Mail</span>
        <input
          type="email"
          name="email"
          placeholder="ihre@firma.ch"
          required
          class="font-body text-[15px] text-ink px-[14px] py-3 border border-stone rounded-md bg-white
                 outline-none transition-all duration-[180ms] ease-standard
                 focus:border-bordeaux-700 focus:ring-2 focus:ring-bordeaux-50 placeholder:text-taupe"
        />
      </label>
      <label class="flex flex-col gap-1.5">
        <span class="text-[11px] tracking-[0.1em] uppercase text-taupe font-semibold">Was soll verbessert werden?</span>
        <textarea
          name="message"
          rows="3"
          placeholder="Kurze Beschreibung Ihrer Situation oder Ihres Anliegens."
          class="font-body text-[15px] text-ink px-[14px] py-3 border border-stone rounded-md bg-white
                 outline-none resize-none transition-all duration-[180ms] ease-standard
                 focus:border-bordeaux-700 focus:ring-2 focus:ring-bordeaux-50 placeholder:text-taupe"
        ></textarea>
      </label>
      <button type="submit" class="btn-primary btn-block mt-1">
        Analyse anfragen
      </button>
    </form>
  </div>

  <!-- Success state -->
  <div id="success-state" class="hidden text-center py-3.5">
    <span class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-positive-soft text-positive mb-4">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="20 6 9 17 4 12"/>
      </svg>
    </span>
    <h2 class="font-display font-medium text-[28px] tracking-[-0.02em] text-ink mb-2">Anfrage erhalten.</h2>
    <p class="text-[15px] leading-relaxed text-slate mb-5">Vielen Dank. Ich melde mich innerhalb von 24 Stunden persönlich.</p>
    <button id="modal-close-btn-2" class="btn-ghost">Schließen</button>
  </div>
</dialog>

<script>
  document.getElementById('modal-close-btn-2')?.addEventListener('click', () => {
    (document.getElementById('contact-modal') as HTMLDialogElement)?.close();
  });
</script>

<style>
  dialog::backdrop {
    background: rgba(21,20,23,0.55);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
  dialog[open] {
    animation: modal-in 420ms cubic-bezier(0.16,1,0.3,1) both;
  }
  @keyframes modal-in {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: none; }
  }
</style>
