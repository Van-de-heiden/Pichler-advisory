---
---

<section class="max-w-[1240px] mx-auto px-10 pt-[168px] pb-24" id="top">
  <div class="grid lg:grid-cols-[1.15fr_0.85fr] gap-16 items-center">

    <!-- Copy -->
    <div class="reveal">
      <span class="eyebrow block mb-[22px]">Für Inhaber, die weiterdenken</span>

      <h1 class="font-display font-medium text-ink m-0 mb-6 leading-[0.98] tracking-[-0.04em]"
          style="font-size: clamp(3.5rem, 6vw, 5rem);">
        Bereit für den<br />nächsten
        <em class="italic text-bordeaux-700" style="font-style: italic;">Schritt?</em>
      </h1>

      <p class="text-[19px] leading-[1.65] text-slate max-w-[46ch] m-0 mb-[34px]">
        Ich unterstütze KMU-Inhaber dabei, ihren Betrieb klarer zu sehen, digitale Schwachstellen zu beheben und Abläufe so zu verbessern, dass im Alltag mehr Übersicht entsteht.
      </p>

      <div class="flex items-center gap-3.5 mb-[52px] flex-wrap">
        <button data-open-contact class="btn-primary btn-lg">
          Betriebsanalyse anfragen
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </button>
        <a href="/leistungen" class="btn-ghost">Leistungen ansehen</a>
      </div>

      <div class="flex items-center gap-7 flex-wrap">
        <div class="flex flex-col gap-1">
          <span class="font-display text-[30px] font-medium text-ink leading-none whitespace-nowrap">2026</span>
          <span class="text-[12px] tracking-[0.08em] uppercase text-taupe">Gründungsjahr</span>
        </div>
        <span class="w-px h-9 bg-stone"></span>
        <div class="flex flex-col gap-1">
          <span class="font-display text-[30px] font-medium text-ink leading-none whitespace-nowrap">KMU</span>
          <span class="text-[12px] tracking-[0.08em] uppercase text-taupe">Fokus</span>
        </div>
        <span class="w-px h-9 bg-stone"></span>
        <div class="flex flex-col gap-1">
          <span class="font-display text-[30px] font-medium text-ink leading-none whitespace-nowrap">Schweiz</span>
          <span class="text-[12px] tracking-[0.08em] uppercase text-taupe">Standort</span>
        </div>
      </div>
    </div>

    <!-- Image -->
    <div class="reveal shadow-lg rounded-xl overflow-hidden aspect-[3/4] relative lg:block hidden">
      <img
        src="/assets/maurus-welcome.png"
        alt="Maurus Pichler, Gründer von Pichler Advisory"
        class="absolute inset-0 w-full h-full object-cover" style="object-position: 65% 15%;"
        onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
      />
      <!-- Fallback charcoal plate -->
      <div class="absolute inset-0 bg-charcoal hidden flex-col justify-end p-6"
           style="display:none; background:#262126;">
        <div class="absolute inset-0 pointer-events-none"
             style="background: radial-gradient(80% 120% at 85% 0%, rgba(90,15,27,0.5), transparent 60%);"></div>
        <img src="/assets/shield.png" alt="" class="absolute w-3/5 max-w-[200px] opacity-[0.06] invert pointer-events-none"
             style="top:50%;left:50%;transform:translate(-50%,-50%)" />
        <span class="relative text-[11px] tracking-[0.18em] uppercase text-stone/50">Schweiz · Advisory · 2026</span>
      </div>
    </div>

  </div>
</section>
