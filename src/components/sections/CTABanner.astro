---
---

<section class="max-w-[1240px] mx-auto px-10 py-[110px]">
  <div class="max-w-[620px] mx-auto text-center reveal">

    <!-- Diamond divider -->
    <span class="diamond-divider mb-6 inline-flex">
      <span class="dd-rule"></span>
      <span class="dd-dia"></span>
      <span class="dd-rule"></span>
    </span>

    <span class="eyebrow block mb-5">Für Inhaber, die weiterdenken</span>

    <h2 class="font-display font-medium text-ink m-0 mb-[18px]"
        style="font-size: clamp(2.4rem, 4vw, 3.4rem); line-height: 1.06; letter-spacing: -0.03em;">
      Bereit für den nächsten Schritt?
    </h2>
    <p class="text-[18px] leading-[1.65] text-slate m-0 mb-[34px]">
      Wenn Ihr Betrieb gut läuft, aber im Alltag zu viel Reibung entsteht, lohnt sich ein klarer Blick von aussen. Ich helfe Ihnen, Schwachstellen zu erkennen, digitale Möglichkeiten sinnvoll zu nutzen und konkrete Verbesserungen umzusetzen.
    </p>

    <div class="flex items-center justify-center gap-4 flex-wrap">
      <button data-open-contact class="btn-primary btn-lg">
        Erstgespräch vereinbaren
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </button>
      <a href="/kontakt" class="btn-ghost">Oder direkt schreiben</a>
    </div>

  </div>
</section>
