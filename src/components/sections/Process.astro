---
const phases = [
  {
    num: '01',
    title: 'Verstehen',
    desc: 'Ich will wissen, wie Ihr Betrieb wirklich funktioniert — nicht wie er auf dem Papier aussieht. Was läuft gut, was frisst zu viel Kraft, wo fehlt Übersicht?',
  },
  {
    num: '02',
    title: 'Analysieren',
    desc: 'Ich schaue mir den Betrieb systematisch an: Aussenwirkung, Abläufe, Kennzahlen, digitale Infrastruktur. Was funktioniert, was nicht — und wo liegt ungenutztes Potenzial?',
  },
  {
    num: '03',
    title: 'Priorisieren',
    desc: 'Nicht alles auf einmal. Ich helfe Ihnen, die Massnahmen zu bestimmen, die wirklich etwas bewegen — nach Impact und Aufwand. Quick Wins zuerst.',
  },
  {
    num: '04',
    title: 'Umsetzen',
    desc: 'Ich setze konkrete Dinge um: neue Website, bessere Prozesse, ein einfaches Cockpit, klarere Angebotsstruktur. Keine Konzepte, die in der Schublade landen.',
  },
  {
    num: '05',
    title: 'Messen',
    desc: 'Ich definiere einfache Messpunkte, damit klar ist, was sich wirklich verändert hat — und wo weiter angesetzt werden soll.',
  },
  {
    num: '06',
    title: 'Weiterentwickeln',
    desc: 'Auf Wunsch begleite ich Sie laufend weiter — monatlich, projektweise oder bei Bedarf. Ein Betrieb ist nie fertig.',
  },
];
---

<section class="max-w-[1240px] mx-auto px-10 py-24" id="vorgehen">
  <div class="grid lg:grid-cols-[0.85fr_1.15fr] gap-16 items-start">

    <!-- Left: heading -->
    <div class="reveal lg:sticky lg:top-28">
      <span class="eyebrow block mb-4">Wie ich vorgehe</span>
      <h2 class="font-display font-medium text-ink mt-4 mb-[18px]"
          style="font-size: clamp(2.2rem, 3.4vw, 3rem); line-height: 1.08; letter-spacing: -0.03em;">
        Erst verstehen.<br />
        <em class="italic text-bordeaux-700" style="font-style:italic;">Dann umsetzen.</em>
      </h2>
      <p class="text-[18px] leading-[1.65] text-slate mb-8">
        Ich beginne nicht mit fertigen Lösungen. Ich will zuerst verstehen, wie der Betrieb wirklich funktioniert — dann wird priorisiert und Schritt für Schritt umgesetzt.
      </p>

      <div class="rounded-xl overflow-hidden aspect-[4/3] relative bg-mist border border-stone/50 shadow-sm">
        <img
          src="/assets/room_normal.png"
          alt="Beratungssituation"
          class="w-full h-full object-cover"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
        />
        <div class="absolute inset-0 hidden items-center justify-center p-10" style="display:none; background:#EEEAE3;">
          <div class="flex flex-col items-center gap-3 text-center">
            <img src="/assets/shield.png" alt="" class="h-16 w-auto opacity-15" />
            <p class="font-display text-[20px] font-medium text-ink/40 tracking-tight leading-snug">
              Substanz erkennen.<br />Systeme bauen.<br />Wirkung erzeugen.
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Right: phase list -->
    <div class="flex flex-col gap-6">
      {phases.map((p, i) => (
        <div
          class="border-t border-mist pt-[22px] flex gap-5 items-start reveal"
          style={`transition-delay: ${i * 60}ms`}
        >
          <span class="font-display text-[20px] font-medium text-gold-700 flex-shrink-0 w-8 mt-0.5">
            {p.num}
          </span>
          <div>
            <h3 class="text-[17px] font-semibold text-ink m-0 mb-[5px]">{p.title}</h3>
            <p class="text-[15px] leading-[1.6] text-slate m-0">{p.desc}</p>
          </div>
        </div>
      ))}

      <div class="pt-6 reveal">
        <a href="/vorgehen" class="btn-ghost px-0">
          Vorgehen im Detail ansehen
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>

  </div>
</section>
