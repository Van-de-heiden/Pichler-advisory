---
interface Props {
  currentPath?: string;
}
const { currentPath = '/' } = Astro.props;

const links = [
  { href: '/leistungen',  label: 'Leistungen' },
  { href: '/vorgehen',    label: 'Vorgehen'   },
  { href: '/ueber-uns',   label: 'Über uns'   },
];
---

<header
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-50 border-b border-transparent
         transition-all duration-[280ms] ease-standard"
>
  <div class="section-inner py-[18px] flex items-center justify-between gap-7">

    <!-- Brand -->
    <a href="/" class="flex items-center gap-3 no-underline flex-shrink-0">
      <img src="/assets/shield.png" alt="" class="h-[34px] w-auto" />
      <span class="font-display text-[17px] font-semibold tracking-[0.18em] text-bordeaux-700 uppercase whitespace-nowrap hidden sm:block">
        Pichler Advisory
      </span>
    </a>

    <!-- Desktop nav links -->
    <nav class="hidden lg:flex gap-[30px]" aria-label="Hauptnavigation">
      {links.map((l) => (
        <a
          href={l.href}
          class:list={['nav-link', { 'is-active': currentPath.startsWith(l.href.split('#')[0]) && l.href !== '/' }]}
        >
          {l.label}
        </a>
      ))}
    </nav>

    <!-- Actions -->
    <div class="flex items-center gap-4">
      <button
        data-open-contact
        class="btn-primary text-[14px] px-5 py-[11px] hidden sm:inline-flex"
      >
        Gespräch anfragen
      </button>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden flex flex-col gap-[5px] p-1.5 text-ink"
        aria-label="Menü öffnen"
      >
        <span class="block w-[22px] h-0.5 bg-current"></span>
        <span class="block w-[22px] h-0.5 bg-current"></span>
        <span class="block w-[16px] h-0.5 bg-current"></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden lg:hidden bg-white/95 backdrop-blur-sm border-t border-mist"
  >
    <nav class="section-inner py-5 flex flex-col gap-4">
      {links.map((l) => (
        <a href={l.href} class="text-[15px] font-medium text-ink py-1">{l.label}</a>
      ))}
      <button
        data-open-contact
        class="btn-primary mt-2 self-start"
      >
        Gespräch anfragen
      </button>
    </nav>
  </div>
</header>

<style>
  #site-nav.is-scrolled {
    background: rgba(255,255,255,0.88);
    -webkit-backdrop-filter: blur(14px);
    backdrop-filter: blur(14px);
    border-bottom-color: #EEEAE3;
    box-shadow: 0 1px 3px rgba(21,20,23,0.06), 0 1px 2px rgba(21,20,23,0.04);
  }
</style>
