---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  noIndex?: boolean;
  jsonLd?: object | object[];
  breadcrumbs?: Array<{ name: string; url: string }>;
}

const {
  title,
  description,
  image = '/og-image.png',
  noIndex = false,
  jsonLd,
  breadcrumbs,
} = Astro.props;

const SITE = 'https://pichler-advisory.ch';

const siteTitle = title;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? SITE);
const ogImage = new URL(image, Astro.site ?? SITE);

const defaultJsonLd = {
  '@context': 'https://schema.org',
  '@type': ['ProfessionalService', 'LocalBusiness'],
  name: 'Pichler Advisory',
  alternateName: 'Pichler Advisory KMU-Beratung',
  description: 'Unternehmensberatung für KMU-Inhaber in der Schweiz. Betriebsanalyse, operative Verbesserung, Prozessoptimierung und digitale Systeme für Betriebe mit Substanz. Schwerpunkt Ostschweiz und St. Gallen.',
  url: SITE,
  logo: `${SITE}/assets/shield.svg`,
  image: `${SITE}/og-image.png`,
  telephone: '+41775383064',
  email: 'info@pichler-advisory.ch',
  priceRange: 'CHF 2000–20000',
  founder: {
    '@type': 'Person',
    name: 'Maurus Pichler',
    jobTitle: 'Inhaber & Berater',
    worksFor: { '@type': 'Organization', name: 'Pichler Advisory' },
  },
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Häberlbodenstrasse 17',
    addressLocality: 'Ernetschwil',
    postalCode: '8725',
    addressCountry: 'CH',
    addressRegion: 'Kanton St. Gallen',
  },
  areaServed: [
    { '@type': 'Country', name: 'Switzerland' },
    { '@type': 'AdministrativeArea', name: 'Ostschweiz' },
    { '@type': 'City', name: 'St. Gallen' },
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+41775383064',
    email: 'info@pichler-advisory.ch',
    contactType: 'Kundenberatung',
    availableLanguage: ['German'],
    contactOption: 'TollFree',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'KMU-Beratungsleistungen',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Betriebsanalyse', description: 'Strukturierter Blick auf Ihren Betrieb in 1–3 Tagen.' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Operative Verbesserung', description: 'Prozessoptimierung und Ablaufverbesserung für KMU.' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Digitale Systeme & Cockpit', description: 'Umsatzcockpit, Lead-Tracker und Projektübersicht für KMU.' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Aussenwirkung & Positionierung', description: 'Website-Neuaufbau und Markenkommunikation für KMU.' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Wachstum & Akquise', description: 'Kundengewinnungsprozesse und Lead-Management.' } },
    ],
  },
  sameAs: [],
};

const breadcrumbJsonLd = breadcrumbs && breadcrumbs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((crumb, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: crumb.name,
    item: `${SITE}${crumb.url}`,
  })),
} : null;

const allJsonLd = jsonLd ?? defaultJsonLd;
---

<!doctype html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="canonical" href={canonicalUrl} />

  {noIndex
    ? <meta name="robots" content="noindex,nofollow" />
    : <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1" />
  }

  <title>{siteTitle}</title>
  <meta name="description" content={description} />
  <meta name="author" content="Maurus Pichler" />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonicalUrl} />
  <meta property="og:title"       content={siteTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage} />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale"      content="de_CH" />
  <meta property="og:site_name"   content="Pichler Advisory" />

  <!-- Twitter card -->
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={siteTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />

  <!-- JSON-LD structured data -->
  <script type="application/ld+json" set:html={JSON.stringify(allJsonLd)} />
  {breadcrumbJsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  )}

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Inter:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body>
  <slot />

  <script>
    /* Scroll reveal */
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
    document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

    /* Nav scrolled state */
    const nav = document.getElementById('site-nav');
    const onScroll = () => nav?.classList.toggle('is-scrolled', window.scrollY > 24);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    /* Mobile menu toggle */
    document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.toggle('hidden');
    });

    /* Contact modal open/close */
    const modal = document.getElementById('contact-modal') as HTMLDialogElement | null;
    document.querySelectorAll('[data-open-contact]').forEach((btn) =>
      btn.addEventListener('click', () => modal?.showModal())
    );
    document.getElementById('modal-close-btn')?.addEventListener('click', () => modal?.close());
    modal?.addEventListener('click', (e) => { if (e.target === modal) modal.close(); });

    /* Contact form submit (simulated — wire up a real backend) */
    document.getElementById('contact-form')?.addEventListener('submit', (e) => {
      e.preventDefault();
      document.getElementById('form-state')?.classList.add('hidden');
      document.getElementById('success-state')?.classList.remove('hidden');
    });
  </script>
</body>
</html>
