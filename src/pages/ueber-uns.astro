---
import Base from '../layouts/Base.astro';
import Nav from '../components/layout/Nav.astro';
import Footer from '../components/layout/Footer.astro';
import ContactModal from '../components/ui/ContactModal.astro';

const values = [
  {
    title: 'Unternehmerisch, nicht akademisch',
    desc: 'Ich denke und handle wie ein Unternehmer — nicht wie ein Berater, der Konzepte abliefert. Was nicht umgesetzt wird, zählt nicht.',
  },
  {
    title: 'Substanz über Oberfläche',
    desc: 'Mich interessieren echte Verbesserungen: bessere Prozesse, bessere Zahlen, bessere Steuerung — nicht nur ein schöneres Deckblatt.',
  },
  {
    title: 'Ehrlichkeit vor Gefälligkeit',
    desc: 'Ich sage, was wirklich los ist. Auch wenn es unbequem ist. Denn nur mit einer ehrlichen Analyse entsteht echte Verbesserung.',
  },
  {
    title: 'Nah am Betrieb',
    desc: 'Ich will Betriebe wirklich kennenlernen: Prozesse, Zahlen, Engpässe, Potenziale. Nicht aus der Distanz, sondern von innen.',
  },
];
---

<Base
  title="Über uns"
  description="Pichler Advisory ist eine inhabergeführte Advisory-Marke aus der Schweiz. Gegründet von Maurus Pichler — mit dem Anspruch, echte Betriebe substanziell besser zu machen."
>
  <Nav currentPath="/ueber-uns" />
  <main>

    <!-- Page hero -->
    <div class="max-w-[1240px] mx-auto px-10 pt-[140px] pb-16">
      <div class="max-w-[680px] reveal">
        <span class="eyebrow block mb-4">Über Pichler Advisory</span>
        <h1 class="font-display font-medium text-ink m-0 mb-5"
            style="font-size: clamp(3rem, 5vw, 4.5rem); line-height: 1.0; letter-spacing: -0.03em;">
          Eine erste Generation.<br />
          <em class="italic text-bordeaux-700">Ein klarer Anspruch.</em>
        </h1>
        <p class="text-[19px] leading-[1.65] text-slate m-0">
          Pichler Advisory ist aus Praxis entstanden: aus Unternehmertum, digitalem Business und dem Anspruch, echte Betriebe substanziell weiterzubringen.
        </p>
      </div>
    </div>

    <!-- Founder story -->
    <div class="max-w-[1240px] mx-auto px-10 pb-20">
      <div class="grid lg:grid-cols-2 gap-16 items-start">

        <!-- Photo + quote plate -->
        <div class="reveal">
          <div class="rounded-xl overflow-hidden shadow-md relative bg-mist border border-stone/50" style="aspect-ratio: 4/3;">
            <img
              src="/assets/maurus.jpg"
              alt="Maurus Pichler, Gründer von Pichler Advisory"
              class="w-full h-full object-cover" style="object-position: 50% 15%;"
              onerror="this.style.display='none';"
            />
            <div class="absolute bottom-0 left-0 right-0 p-6" style="background: linear-gradient(to top, rgba(30,27,30,0.8) 0%, transparent 100%);">
              <p class="font-display text-[19px] font-medium text-ivory/90 leading-snug tracking-tight mb-2">
                „Gute Betriebe verdienen einen Auftritt, der ihrer Leistung gerecht wird."
              </p>
              <p class="text-[12px] text-stone/60">Maurus Pichler, Gründer</p>
            </div>
          </div>

          <!-- Stats -->
          <div class="grid grid-cols-3 gap-px bg-stone/30 rounded-xl overflow-hidden mt-4">
            {[
              { title: 'Eigene Projekte',   desc: 'Von Idee bis Umsetzung' },
              { title: 'Digitale Praxis',   desc: 'Werkzeuge sinnvoll genutzt' },
              { title: 'Echte Betriebe',    desc: 'Nah an Alltag und Wirkung' },
            ].map((s) => (
              <div class="bg-white px-4 py-4">
                <span class="text-[13px] font-semibold text-ink leading-tight block mb-1">{s.title}</span>
                <span class="text-[11px] leading-[1.4] text-taupe block">{s.desc}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Story -->
        <div class="reveal">
          <h2 class="font-display font-medium text-ink mb-5"
              style="font-size: clamp(1.8rem, 2.4vw, 2.2rem); line-height: 1.1; letter-spacing: -0.02em;">
            Wer steckt hinter Pichler Advisory?
          </h2>
          <div class="flex flex-col gap-4 text-[16px] leading-[1.75] text-slate">
            <p>
              Ich bin Maurus Nic Ramon Pichler, Gründer von Pichler Advisory. Mein Zugang zu Unternehmen kommt nicht aus Distanz, sondern aus eigener Verantwortung: Produkte aufbauen, Entscheidungen treffen, Kunden verstehen, Wirkung erzeugen.
            </p>
            <p>
              Mit Dominus entwickle ich parallel ein technologiebasiertes Immobilienunternehmen, das Immobilien und Investments zugänglicher, transparenter und breiter nutzbar machen soll. Dort beschäftige ich mich mit digitalen Beteiligungsmodellen, Investorenlogik, Markenaufbau, Plattformdenken und der Frage, wie Kapital, Technologie und reale Werte sinnvoll zusammenfinden.
            </p>
            <p>
              Gleichzeitig absolviere ich die Ausbildung zum Entwickler digitales Business EFZ. Dadurch verbinde ich unternehmerisches Denken mit modernen Werkzeugen, digitalen Prozessen, Daten, Strategie und konkreter Umsetzung.
            </p>
            <p>
              Pichler Advisory ist die Konsequenz daraus: ein klarer Blick von aussen, verbunden mit echtem Interesse am Betrieb. Ich will nicht komplizierter machen, was einfach sein sollte. Ich will sichtbar machen, wo Potenzial liegt, und helfen, es praktisch umzusetzen.
            </p>
          </div>
        </div>

      </div>
    </div>

    <!-- Values -->
    <div class="bg-ivory border-t border-mist">
      <div class="max-w-[1240px] mx-auto px-10 py-20">
        <div class="max-w-[560px] mb-12 reveal">
          <span class="eyebrow block mb-4">Meine Haltung</span>
          <h2 class="font-display font-medium text-ink mt-4"
              style="font-size: clamp(2rem, 3vw, 2.6rem); line-height: 1.08; letter-spacing: -0.03em;">
            Was mich antreibt.
          </h2>
        </div>
        <div class="grid md:grid-cols-2 gap-6">
          {values.map((v, i) => (
            <div
              class="bg-white border border-mist rounded-xl p-7 shadow-sm reveal"
              style={`transition-delay: ${(i % 2) * 60}ms`}
            >
              <h3 class="font-body text-[17px] font-semibold text-ink mb-3">{v.title}</h3>
              <p class="text-[15px] leading-[1.65] text-slate m-0">{v.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- What drives me -->
    <div class="relative bg-charcoal overflow-hidden">
      <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(70% 110% at 80% 0%, rgba(90,15,27,0.5), transparent 60%);"></div>
      <div class="relative max-w-[1240px] mx-auto px-10 py-24 reveal">
        <div class="grid lg:grid-cols-2 gap-16 items-center">
          <div>
            <span class="eyebrow eyebrow-gold block mb-4">Was mich antreibt</span>
            <h2 class="font-display font-medium text-ivory mt-4 mb-5"
                style="font-size: clamp(2rem, 3vw, 2.8rem); line-height: 1.1; letter-spacing: -0.03em;">
              Wissen teilen.<br />
              <em class="italic" style="font-style:italic;">Wirkung erzeugen.</em>
            </h2>
            <p class="text-[17px] leading-[1.7] text-stone mb-5">
              Ich kenne die Möglichkeiten moderner Technologie — und ich kenne die Best Practices, wie man sie so einsetzt, dass sie wirklich etwas verändern. Dieses Wissen interessiert mich nicht als Selbstzweck, sondern als Werkzeug für echte Betriebe.
            </p>
            <p class="text-[17px] leading-[1.7] text-stone">
              KMU-Inhaber arbeiten 50, 60 Stunden die Woche. Sie haben keine Zeit, sich durch Software-Demos zu kämpfen oder teure Agenturen zu briefen. Ich bringe das Wissen direkt — und setze um, was wirklich hilft.
            </p>
          </div>
          <div class="flex flex-col gap-5">
            {[
              { icon: `<path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>`, label: 'Technologie-Expertise', text: 'KI, Automatisierung, digitale Systeme — ich kenne die Werkzeuge und wie man sie ohne IT-Abteilung einsetzt.' },
              { icon: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`, label: 'Direkte Umsetzung', text: 'Kein Konzeptpapier. Ich setze konkrete Massnahmen um — von der Website bis zum Cockpit.' },
              { icon: `<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>` , label: 'Auf Augenhöhe', text: 'Ich spreche mit Inhabern, nicht über sie. Ich verstehe den Betrieb zuerst — dann handle ich.' },
            ].map(item => (
              <div class="flex gap-4 items-start">
                <span class="flex-shrink-0 w-10 h-10 rounded-lg bg-bordeaux-900/50 border border-bordeaux-700/30 text-bordeaux-300 flex items-center justify-center">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" set:html={item.icon} />
                </span>
                <div>
                  <p class="text-[14px] font-semibold text-ivory/90 mb-1">{item.label}</p>
                  <p class="text-[14px] leading-[1.6] text-stone/70">{item.text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="max-w-[1240px] mx-auto px-10 py-20 text-center reveal">
      <h2 class="font-display font-medium text-ink m-0 mb-4"
          style="font-size: clamp(2rem, 3vw, 2.6rem); line-height: 1.08; letter-spacing: -0.03em;">
        Klingt das nach dem richtigen Partner?
      </h2>
      <p class="text-[17px] leading-[1.65] text-slate mb-8 max-w-[40ch] mx-auto">
        Ich freue mich auf ein offenes Erstgespräch — unverbindlich, direkt und ohne Floskeln.
      </p>
      <button data-open-contact class="btn-primary btn-lg">
        Erstgespräch vereinbaren
      </button>
    </div>

  </main>
  <Footer />
  <ContactModal />
</Base>
