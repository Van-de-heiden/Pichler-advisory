---
import Base from '../layouts/Base.astro';
import Nav from '../components/layout/Nav.astro';
import Footer from '../components/layout/Footer.astro';
import ContactModal from '../components/ui/ContactModal.astro';

const services = [
  {
    id: 'betriebsanalyse',
    icon: `<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>`,
    tag: 'Einstieg',
    tagStyle: 'core',
    title: 'Betriebsanalyse',
    lede: 'Der strukturierte Blick auf Ihren Betrieb — in 1 bis 3 Tagen.',
    body: [
      'Wir analysieren Ihren Betrieb systematisch: Aussenwirkung, digitale Präsenz, interne Abläufe, Kundenansprache, Kennzahlen und operative Struktur.',
      'Das Ergebnis ist ein konkreter Bericht mit Schwachstellenanalyse, Quick Wins und priorisierten Massnahmenempfehlungen — keine theoretischen Konzepte, sondern direkt nutzbare Erkenntnisse.',
      'Die Betriebsanalyse ist der ideale Einstieg in die Zusammenarbeit mit Pichler Advisory: Sie schaffen Klarheit darüber, wo Ihr Betrieb wirklich steht und welche Hebel am stärksten wirken.',
    ],
    includes: ['Analyse der Website und digitalen Präsenz', 'Bewertung interner Abläufe', 'Kennzahlen und Steuerungssituation', 'Quick Wins und Massnahmenplan', 'Persönliches Feedbackgespräch'],
    duration: '1–3 Tage Sprint',
    price: 'Auf Anfrage',
  },
  {
    id: 'operative-verbesserung',
    icon: `<circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>`,
    tag: 'Umsetzung',
    tagStyle: 'core',
    title: 'Operative Verbesserung',
    lede: 'Reibung reduzieren, Abläufe straffen, Effizienz steigern.',
    body: [
      'Viele KMU funktionieren gut — aber langsamer, aufwändiger und fehleranfälliger als nötig. Offertprozesse, Kundenkommunikation, Verwaltungsaufgaben und interne Abstimmungen kosten unnötig Zeit und Energie.',
      'Pichler Advisory vereinfacht und strukturiert diese Bereiche: mit klareren Workflows, besseren Vorlagen, sinnvollen digitalen Hilfen und mehr Übersicht im Tagesgeschäft.',
    ],
    includes: ['Prozessanalyse und Optimierung', 'Vereinfachung von Offert- und Kundenprozessen', 'Digitale Organisation und Ablagestruktur', 'Aufbau klarerer Arbeitsabläufe', 'Reduktion administrativen Aufwands'],
    duration: 'Projektbasis',
    price: 'CHF 2\'000 – 20\'000',
  },
  {
    id: 'digitale-systeme',
    icon: `<rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>`,
    tag: 'Systeme',
    tagStyle: 'core',
    title: 'Digitale Systeme & Cockpit',
    lede: 'Die richtigen Zahlen. Auf einen Blick.',
    body: [
      'Viele Unternehmer führen ihren Betrieb aus dem Bauch heraus — weil Daten verstreut, unübersichtlich oder gar nicht vorhanden sind. Pichler Advisory baut einfache, visuelle Systeme, die das ändern.',
      'Ob Umsatzcockpit, Lead-Tracker, Projektübersicht oder operative Performance-Indikatoren: wir schaffen die Grundlage für klarere Entscheidungen und bessere Steuerung.',
    ],
    includes: ['Performance-Cockpit und Dashboard', 'Umsatz- und Auftragsübersicht', 'Lead- und Akquise-Tracking', 'Projekt- und Aufgabenübersicht', 'Datenverbindung und Automatisierung'],
    duration: 'Aufbau + optional Retainer',
    price: 'CHF 2\'000 – 10\'000 Aufbau',
  },
  {
    id: 'aussenwirkung',
    icon: `<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>`,
    tag: 'Auftritt',
    tagStyle: 'selective',
    title: 'Aussenwirkung & Positionierung',
    lede: 'Professionell. Glaubwürdig. Merkbar.',
    body: [
      'Ein Betrieb mit guter Substanz verdient einen Auftritt, der das zeigt. Viele KMU haben eine schwache, veraltete oder uninspirierte digitale Präsenz — und verlieren dadurch Vertrauen bei Kunden, Partnern und potenziellen Nachfolgern.',
      'Pichler Advisory verbessert Website, Positionierung und Angebotskommunikation: nicht mit Agenturkitsch, sondern mit Klarheit, Substanz und professionellem Ausdruck.',
    ],
    includes: ['Website-Analyse und Neuaufbau', 'Angebotskommunikation und Positionierung', 'Digitale Präsenz und Auftritt', 'Vertrauensaufbau bei Zielgruppen', 'Konsistentes Erscheinungsbild'],
    duration: 'Projektbasis',
    price: 'Auf Anfrage',
  },
  {
    id: 'wachstum',
    icon: `<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>`,
    tag: 'Wachstum',
    tagStyle: 'selective',
    title: 'Wachstum & Akquise',
    lede: 'Saubere Hebel statt leerer Versprechen.',
    body: [
      'Wachstum ist kein Marketing-Begriff. Es ist das Ergebnis von klarer Kundenansprache, funktionierenden Lead-Prozessen und einem Angebot, das überzeugt.',
      'Pichler Advisory analysiert, wie Ihr Betrieb aktuell Kunden gewinnt — und wo die grössten Hebel liegen, um diesen Prozess zu verbessern. Keine teuren Kampagnen, keine Heilsversprechen.',
    ],
    includes: ['Analyse Kundengewinnung und Vertriebsprozess', 'Lead-Prozesse und Follow-up', 'Angebotsstruktur und Kommunikation', 'Pragmatische Wachstumsmassnahmen', 'Monatlicher Retainer möglich'],
    duration: 'Analyse + Umsetzung',
    price: 'CHF 300 – 1\'000+/Monat Retainer',
  },
  {
    id: 'turnaround',
    icon: `<polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>`,
    tag: 'Turnaround',
    tagStyle: 'selective',
    title: 'Turnaround-Unterstützung',
    lede: 'Substanz erkennen und heben.',
    body: [
      'Besonders interessant für Pichler Advisory sind Betriebe, die eigentlich gute Substanz haben — aber schlecht geführt, schwach positioniert, digital rückständig oder intern unübersichtlich sind.',
      'In solchen Situationen gibt es oft grosse Hebel. Wir helfen, diese zu identifizieren, zu priorisieren und umzusetzen — mit unternehmerischem Verstand und ohne beschönigende Beratungssprache.',
    ],
    includes: ['Tiefe Betriebsanalyse', 'Identifikation von Substanz und Schwächen', 'Sofortmassnahmen und Prioritäten', 'Operative Begleitung und Umsetzung', 'Strategische Neuausrichtung'],
    duration: 'Auf Anfrage',
    price: 'Auf Anfrage',
  },
];
---

<Base
  title="Leistungen"
  description="Betriebsanalyse, operative Verbesserung, digitale Systeme, Aussenwirkung, Wachstum und Turnaround-Unterstützung für KMU in der Schweiz."
>
  <Nav currentPath="/leistungen" />
  <main>

    <!-- Page hero -->
    <div class="max-w-[1240px] mx-auto px-10 pt-[140px] pb-16">
      <div class="max-w-[680px] reveal">
        <span class="eyebrow block mb-4">Leistungen</span>
        <h1 class="font-display font-medium text-ink m-0 mb-5"
            style="font-size: clamp(3rem, 5vw, 4.5rem); line-height: 1.0; letter-spacing: -0.03em;">
          Was Pichler Advisory für Ihren Betrieb tun kann.
        </h1>
        <p class="text-[19px] leading-[1.65] text-slate m-0">
          Von der ersten Analyse bis zur laufenden Begleitung — sechs Bereiche, die zusammen oder einzeln echte Wirkung entfalten.
        </p>
      </div>
    </div>

    <!-- Service detail list -->
    <div class="max-w-[1240px] mx-auto px-10 pb-24">
      <div class="flex flex-col gap-20">
        {services.map((s, i) => (
          <div id={s.id} class="grid lg:grid-cols-[1fr_2fr] gap-12 items-start pt-10 border-t border-mist reveal">

            <!-- Left: icon + meta -->
            <div>
              <span class="inline-flex items-center justify-center w-14 h-14 rounded-xl bg-bordeaux-50 text-bordeaux-700 mb-5">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon} />
              </span>
              <span class:list={[
                'inline-block text-[10.5px] tracking-[0.12em] uppercase font-semibold px-3 py-[5px] rounded-pill mb-4',
                s.tagStyle === 'core'
                  ? 'bg-bordeaux-50 text-bordeaux-700'
                  : 'border border-gold-500 text-gold-700'
              ]}>
                {s.tag}
              </span>
              <div class="mt-2 flex flex-col gap-3 text-[14px] text-slate">
                <div>
                  <span class="block text-[11px] tracking-[0.1em] uppercase text-taupe mb-1">Dauer</span>
                  <span class="text-ink font-medium">{s.duration}</span>
                </div>
                <div>
                  <span class="block text-[11px] tracking-[0.1em] uppercase text-taupe mb-1">Investition</span>
                  <span class="text-ink font-medium">{s.price}</span>
                </div>
              </div>
            </div>

            <!-- Right: body -->
            <div>
              <h2 class="font-display font-medium text-ink mb-2"
                  style="font-size: clamp(1.8rem, 2.6vw, 2.4rem); line-height: 1.1; letter-spacing: -0.02em;">
                {s.title}
              </h2>
              <p class="text-[18px] font-medium text-bordeaux-700 mb-5 leading-snug">{s.lede}</p>

              {s.body.map((p) => (
                <p class="text-[16px] leading-[1.7] text-slate mb-4">{p}</p>
              ))}

              <div class="mt-6 p-5 bg-mist rounded-xl border border-stone/50">
                <p class="text-[11px] tracking-[0.1em] uppercase text-taupe font-semibold mb-3">Umfang</p>
                <ul class="flex flex-col gap-2 list-none p-0 m-0">
                  {s.includes.map((item) => (
                    <li class="flex items-center gap-2.5 text-[14.5px] text-slate">
                      <span class="flex-shrink-0 w-4 h-4 rounded-full bg-bordeaux-50 text-bordeaux-700 flex items-center justify-center">
                        <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                          <polyline points="20 6 9 17 4 12"/>
                        </svg>
                      </span>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>

              <button data-open-contact class="btn-primary mt-6">
                Anfragen
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </button>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="bg-ivory border-t border-mist">
      <div class="max-w-[1240px] mx-auto px-10 py-20 text-center reveal">
        <h2 class="font-display font-medium text-ink m-0 mb-4"
            style="font-size: clamp(2rem, 3vw, 2.6rem); line-height: 1.08; letter-spacing: -0.03em;">
          Welches Thema passt zu Ihrem Betrieb?
        </h2>
        <p class="text-[17px] leading-[1.65] text-slate mb-8 max-w-[42ch] mx-auto">
          Oft ist eine kurze Betriebsanalyse der beste Einstieg — sie zeigt, wo der Hebel am grössten ist.
        </p>
        <button data-open-contact class="btn-primary btn-lg">
          Betriebsanalyse anfragen
        </button>
      </div>
    </div>

  </main>
  <Footer />
  <ContactModal />
</Base>
