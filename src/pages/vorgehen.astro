---
import Base from '../layouts/Base.astro';
import Nav from '../components/layout/Nav.astro';
import Footer from '../components/layout/Footer.astro';
import ContactModal from '../components/ui/ContactModal.astro';

const phases = [
  {
    num: '01',
    title: 'Verstehen',
    subtitle: 'Den Betrieb kennenlernen',
    desc: 'Am Anfang steht ein ehrliches Gespräch. Ich will verstehen, wie Ihr Betrieb wirklich funktioniert — nicht wie er auf dem Papier aussieht. Was sind Ihre Ziele? Wo drückt der Schuh? Was hat schon funktioniert, was nicht? Welche Engpässe nerven täglich? Dieses Gespräch ist keine Checkliste, sondern ein echtes Kennenlernen — und die Basis für alles, was folgt.',
    duration: '1–2 Gespräche',
    outcome: 'Klares Bild der Situation, erste Hypothesen',
    bg: 'light',
  },
  {
    num: '02',
    title: 'Analysieren',
    subtitle: 'Schwächen und Potenziale sichtbar machen',
    desc: 'Systematische Betrachtung des Betriebs aus mehreren Winkeln: Aussenwirkung und digitale Präsenz, interne Abläufe und Prozesse, Kundenansprache und Akquise, Kennzahlen und Steuerungssituation. Ich schaue, was funktioniert, was ineffizient ist und wo ungenutztes Potenzial liegt — ohne Vorurteile, aber mit klarem Blick.',
    duration: '1–3 Tage',
    outcome: 'Dokumentierte Schwachstellen und Stärken',
    bg: 'mist',
  },
  {
    num: '03',
    title: 'Priorisieren',
    subtitle: 'Die richtigen Hebel bestimmen',
    desc: 'Nicht alles auf einmal. Auf Basis der Analyse bestimme ich, welche Massnahmen den grössten Impact bei welchem Aufwand haben. Ich trenne Quick Wins, die sofort umgesetzt werden können, von Projekten, die mehr Zeit brauchen. Das Ergebnis ist ein klarer, priorisierter Massnahmenplan.',
    duration: '1 Workshop / Gespräch',
    outcome: 'Priorisierter Massnahmenplan mit Quick Wins',
    bg: 'light',
  },
  {
    num: '04',
    title: 'Umsetzen',
    subtitle: 'Konkrete Verbesserungen realisieren',
    desc: 'Der Teil, der zählt. Ich setze die vereinbarten Massnahmen um — neue Website, verbesserter Offertprozess, aufgebautes Cockpit, strukturiertes Angebot, klarere Abläufe. Kein Konzept ohne Umsetzung. Kein Bericht, der in der Schublade landet.',
    duration: 'Je nach Umfang',
    outcome: 'Umgesetzte Massnahmen mit messbarer Wirkung',
    bg: 'dark',
  },
  {
    num: '05',
    title: 'Messen',
    subtitle: 'Wirkung nachvollziehen',
    desc: 'Jede Massnahme braucht einen Massstab. Ich definiere einfache Messpunkte vorab: Hat sich die Angebotsannahme verbessert? Kommen mehr Anfragen? Hat sich der Verwaltungsaufwand reduziert? Lädt die Website schneller? Nach der Umsetzung wird das ehrlich überprüft — ohne Selbstbeweihräucherung.',
    duration: 'Laufend',
    outcome: 'Klare Vorher/Nachher-Vergleiche',
    bg: 'mist',
  },
  {
    num: '06',
    title: 'Weiterentwickeln',
    subtitle: 'Kontinuierlich verbessern',
    desc: 'Ein Betrieb ist nie fertig. Auf Wunsch begleite ich Sie monatlich im Retainer: neue Massnahmen, Website-Weiterentwicklung, Cockpit-Pflege, strategisches Sparring, neue Wachstumsinitiativen. So bleibt der Betrieb in Bewegung — und die Verbesserung ist kein einmaliges Projekt, sondern ein dauerhafter Prozess.',
    duration: 'Monatlich / laufend',
    outcome: 'Kontinuierliche Betriebsverbesserung',
    bg: 'light',
  },
];
---

<Base
  title="Vorgehen – Strukturierte KMU-Beratung von der Analyse bis zur Umsetzung | Pichler Advisory"
  description="In sechs klaren Schritten von der ersten Analyse zur messbaren Verbesserung: So arbeitet Pichler Advisory mit KMU-Inhabern in der Schweiz. Konkret, umsetzungsnah, ohne Konzepte in Schubladen."
  breadcrumbs={[{ name: 'Startseite', url: '/' }, { name: 'Vorgehen', url: '/vorgehen/' }]}
>
  <Nav currentPath="/vorgehen" />
  <main>

    <!-- Page hero -->
    <div class="max-w-[1240px] mx-auto px-10 pt-[140px] pb-20">
      <div class="max-w-[680px] reveal">
        <span class="eyebrow block mb-4">Vorgehen</span>
        <h1 class="font-display font-medium text-ink m-0 mb-5"
            style="font-size: clamp(3rem, 5vw, 4.5rem); line-height: 1.0; letter-spacing: -0.03em;">
          Strukturiert.<br />
          <em class="italic text-bordeaux-700" style="font-style:italic;">Ohne Umwege.</em>
        </h1>
        <p class="text-[19px] leading-[1.65] text-slate m-0">
          Mein Vorgehen folgt einer klaren Logik — von der Analyse bis zur Umsetzung. Sechs Phasen, die zusammen echte Wirkung entfalten.
        </p>
      </div>
    </div>

    <!-- Phase navigator (sticky) -->
    <div id="phase-nav" class="sticky top-[72px] z-20 border-b border-stone/20" style="background: rgba(245,241,235,0.92); backdrop-filter: blur(12px);">
      <div class="max-w-[1240px] mx-auto px-10">
        <div class="flex gap-1 overflow-x-auto py-2.5" style="scrollbar-width:none;">
          {phases.map(p => (
            <a
              href={`#phase-${p.num}`}
              class="phase-pill flex-shrink-0 flex items-center gap-2 px-4 py-1.5 rounded-full text-[12.5px] font-medium text-taupe hover:text-ink hover:bg-stone/40 transition-all duration-[180ms]"
              data-phase={p.num}
            >
              <span class="font-display text-gold-700 text-[14px]">{p.num}</span>
              {p.title}
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Phase sections -->
    {phases.map((p, i) => (
      <div
        id={`phase-${p.num}`}
        class={
          p.bg === 'dark'
            ? 'relative bg-charcoal overflow-hidden'
            : p.bg === 'mist'
            ? 'bg-mist/50 border-y border-stone/20'
            : 'bg-white'
        }
      >
        {p.bg === 'dark' && (
          <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(60% 100% at 75% 0%, rgba(90,15,27,0.4), transparent 60%);" />
        )}

        <div class="relative max-w-[1240px] mx-auto px-10 py-[80px]">

          {p.bg === 'dark' ? (
            <!-- Dark featured layout (Phase 04) -->
            <div class="reveal">
              <div class="flex items-start justify-between flex-wrap gap-8">
                <div class="max-w-[640px]">
                  <div class="flex items-center gap-4 mb-6">
                    <span class="font-display text-[72px] font-medium leading-none text-gold-500/40">{p.num}</span>
                    <div>
                      <span class="text-[11px] tracking-[0.14em] uppercase text-stone/50 block mb-1">{p.subtitle}</span>
                      <h2 class="font-display font-medium text-ivory m-0"
                          style="font-size: clamp(2.2rem, 3.5vw, 3rem); line-height: 1.05; letter-spacing: -0.02em;">
                        {p.title}
                      </h2>
                    </div>
                  </div>
                  <p class="text-[18px] leading-[1.8] text-stone mb-8">{p.desc}</p>
                  <button data-open-contact class="btn-primary">
                    Jetzt anfragen
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                  </button>
                </div>
                <div class="flex flex-col gap-4 min-w-[200px]">
                  <div class="border border-white/10 rounded-xl px-5 py-4 bg-white/5">
                    <span class="text-[10px] tracking-[0.12em] uppercase text-stone/40 block mb-1.5">Dauer</span>
                    <span class="text-[16px] font-medium text-ivory">{p.duration}</span>
                  </div>
                  <div class="border border-bordeaux-700/40 rounded-xl px-5 py-4 bg-bordeaux-900/20">
                    <span class="text-[10px] tracking-[0.12em] uppercase text-bordeaux-300/60 block mb-1.5">Ergebnis</span>
                    <span class="text-[15px] font-medium text-ivory">{p.outcome}</span>
                  </div>
                </div>
              </div>
            </div>
          ) : (
            <!-- Light layout -->
            <div class="grid lg:grid-cols-[180px_1fr] gap-10 lg:gap-20 items-start reveal">

              <!-- Left: number + meta -->
              <div class="flex flex-col gap-4">
                <span class="font-display leading-none text-gold-700/20 select-none"
                      style="font-size: clamp(5rem, 8vw, 7rem); font-weight: 500;">
                  {p.num}
                </span>
                <div class="flex flex-col gap-3">
                  <div class={`rounded-lg px-4 py-3 ${p.bg === 'mist' ? 'bg-white border border-stone/30' : 'bg-mist border border-stone/30'}`}>
                    <span class="text-[10px] tracking-[0.1em] uppercase text-taupe block mb-1">Dauer</span>
                    <span class="text-[13.5px] font-medium text-ink">{p.duration}</span>
                  </div>
                  <div class="rounded-lg px-4 py-3 bg-bordeaux-50 border border-bordeaux-100">
                    <span class="text-[10px] tracking-[0.1em] uppercase text-bordeaux-400 block mb-1">Ergebnis</span>
                    <span class="text-[13.5px] font-medium text-bordeaux-800 leading-snug">{p.outcome}</span>
                  </div>
                </div>
              </div>

              <!-- Right: content -->
              <div class="pt-2">
                <span class="text-[11px] tracking-[0.12em] uppercase text-taupe font-semibold block mb-3">{p.subtitle}</span>
                <h2 class="font-display font-medium text-ink mb-5"
                    style="font-size: clamp(2rem, 3.2vw, 2.8rem); line-height: 1.07; letter-spacing: -0.02em;">
                  {p.title}
                </h2>
                <p class="text-[17px] leading-[1.8] text-slate">{p.desc}</p>
              </div>

            </div>
          )}
        </div>
      </div>
    ))}

    <!-- CTA -->
    <div class="max-w-[1240px] mx-auto px-10 py-24 text-center reveal">
      <span class="diamond-divider mb-8 inline-flex">
        <span class="dd-rule"></span><span class="dd-dia"></span><span class="dd-rule"></span>
      </span>
      <h2 class="font-display font-medium text-ink m-0 mb-4"
          style="font-size: clamp(2rem, 3vw, 2.8rem); line-height: 1.08; letter-spacing: -0.03em;">
        Bereit für den ersten Schritt?
      </h2>
      <p class="text-[17px] leading-[1.65] text-slate mb-8 max-w-[42ch] mx-auto">
        Die Betriebsanalyse ist der ideale Einstieg — kompakt, konkret und direkt umsetzbar.
      </p>
      <a href="/kontakt" class="btn-primary btn-lg">
        Betriebsanalyse anfragen
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

  </main>
  <Footer />
  <ContactModal />
</Base>

<script>
  /* Phase navigator scrollspy */
  const pills = document.querySelectorAll<HTMLAnchorElement>('.phase-pill');
  const sections = document.querySelectorAll<HTMLElement>('[id^="phase-"]');

  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          const id = e.target.id.replace('phase-', '');
          pills.forEach(p => {
            const active = p.dataset.phase === id;
            p.style.background = active ? 'rgba(90,15,27,0.08)' : '';
            p.style.color = active ? '#5A0F1B' : '';
          });
        }
      });
    },
    { rootMargin: '-30% 0px -60% 0px' }
  );

  sections.forEach(s => io.observe(s));

  /* Smooth scroll for phase pills */
  const nav = document.getElementById('phase-nav');
  pills.forEach(pill => {
    pill.addEventListener('click', (e) => {
      e.preventDefault();
      const target = document.querySelector(pill.getAttribute('href')!);
      if (target && nav) {
        const offset = nav.offsetHeight + 72 + 16;
        const top = (target as HTMLElement).getBoundingClientRect().top + window.scrollY - offset;
        window.scrollTo({ top, behavior: 'smooth' });
      }
    });
  });
</script>
