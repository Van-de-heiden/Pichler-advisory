---
const error = Astro.url.searchParams.get('error') === '1';
const from  = Astro.url.searchParams.get('from') || '/';
---

<!doctype html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Zugang — Pichler Advisory</title>
  <meta name="robots" content="noindex,nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;1,500&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Inter', sans-serif;
      background: #1E1B1E;
      min-height: 100dvh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background: radial-gradient(70% 80% at 60% 10%, rgba(90,15,27,0.35), transparent 60%);
      pointer-events: none;
    }
    .card {
      position: relative;
      background: #262126;
      border: 1px solid rgba(216,210,200,0.10);
      border-radius: 16px;
      padding: 48px 44px;
      width: 100%;
      max-width: 420px;
      box-shadow: 0 24px 64px rgba(0,0,0,0.45);
    }
    .logo {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 36px;
    }
    .logo img { height: 28px; width: auto; filter: brightness(0) invert(1); opacity: 0.85; }
    .logo-text {
      font-family: 'Cormorant Garamond', serif;
      font-size: 18px;
      font-weight: 500;
      letter-spacing: 0.04em;
      color: #F5F1EB;
    }
    h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2rem;
      font-weight: 500;
      color: #F5F1EB;
      line-height: 1.1;
      letter-spacing: -0.02em;
      margin-bottom: 6px;
    }
    .subtitle {
      font-size: 14px;
      color: #8A8078;
      margin-bottom: 28px;
      line-height: 1.5;
    }
    .error-box {
      display: flex;
      align-items: center;
      gap: 10px;
      background: rgba(90,15,27,0.25);
      border: 1px solid rgba(90,15,27,0.5);
      border-radius: 8px;
      padding: 12px 14px;
      margin-bottom: 20px;
      font-size: 13.5px;
      color: #E8A0A8;
    }
    .form-group { display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px; }
    label {
      font-size: 11px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #6B6460;
      font-weight: 600;
    }
    input {
      font-family: 'Inter', sans-serif;
      font-size: 15px;
      color: #F5F1EB;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(216,210,200,0.15);
      border-radius: 8px;
      padding: 12px 14px;
      outline: none;
      transition: border-color 200ms, box-shadow 200ms;
    }
    input::placeholder { color: #4A4248; }
    input:focus {
      border-color: rgba(90,15,27,0.7);
      box-shadow: 0 0 0 3px rgba(90,15,27,0.15);
    }
    button[type="submit"] {
      margin-top: 8px;
      width: 100%;
      font-family: 'Inter', sans-serif;
      font-size: 15px;
      font-weight: 600;
      color: #F5F1EB;
      background: #5A0F1B;
      border: none;
      border-radius: 8px;
      padding: 14px 24px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      transition: background 200ms, transform 120ms;
    }
    button[type="submit"]:hover { background: #6E1322; }
    button[type="submit"]:active { transform: scale(0.99); }
    .divider {
      height: 1px;
      background: rgba(216,210,200,0.08);
      margin: 28px 0 20px;
    }
    .footer-note {
      font-size: 12px;
      color: #4A4248;
      text-align: center;
      line-height: 1.5;
    }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">
      <img src="/assets/shield.svg" alt="" />
      <span class="logo-text">Pichler Advisory</span>
    </div>

    <h1>Geschützter Bereich</h1>
    <p class="subtitle">Diese Website ist derzeit nicht öffentlich zugänglich.</p>

    {error && (
      <div class="error-box">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
        Falscher Benutzername oder Passwort.
      </div>
    )}

    <form method="POST" action="/api/login">
      <input type="hidden" name="from" value={from} />

      <div class="form-group">
        <label for="username">Benutzername</label>
        <input
          id="username"
          type="text"
          name="username"
          placeholder="Benutzername eingeben"
          autocomplete="username"
          required
        />
      </div>

      <div class="form-group">
        <label for="password">Passwort</label>
        <input
          id="password"
          type="password"
          name="password"
          placeholder="••••••••••"
          autocomplete="current-password"
          required
        />
      </div>

      <button type="submit">
        Zugang bestätigen
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </button>
    </form>

    <div class="divider"></div>
    <p class="footer-note">Pichler Advisory · Schweiz · 2026</p>
  </div>
</body>
</html>
